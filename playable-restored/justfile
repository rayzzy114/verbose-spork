# Tower Rush Playable Ad

# Запустить dev-сервер
dev:
    npm run dev

# Сбилдить один гео (по умолчанию GB)
build geo="GB":
    VITE_GEO={{geo}} npm run build

# Сбилдить все гео
build-all:
    npm run build:all

# Превью собранного билда
preview:
    npm run preview

# Открыть в браузере (dev)
open:
    xdg-open http://localhost:5173
